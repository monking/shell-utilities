  );
  SCRIPT_VERSION="${SCRIPT_VERSIONS[0]}";
  SCRIPT_VERSION_NICE="v${SCRIPT_VERSION%%  *}";

  HEADER_IGNORE_STATEMENT="Metadata follows file paths, separated by: "
  HEADER_IGNORE_TAB_LABEL='Tab character "\t"'

  g_IFS="$IFS"
  export g_IFS

  showHelp() {
    echo "USAGE: $SCRIPT_USAGE";
    echo "PURPOSE: $SCRIPT_PURPOSE";
    echo "";
    echo "OPTIONS:";
    SCRIPT_OPTIONS=(
      "-h, --help, help"
      "    Show this help"
      ""
      "-a CMD"
      "    Hashing algorithm to use. Currently supported: 'sha256', 'b2', 'sha256e' (alias 'annex'). env: SUMDIR_ALGORITHM."
      ""
      "-r                "
      "    Recurse into directory. env: SUMDIR_SHOULD_RECURSE"
      ""
      "-L                "
      "    Dereference (follow) symlinks. env: SUMDIR_SHOULD_DEREFERENCE"
      ""
      "-1, --single"
      "    Remove existing *SUM* SUMFILEs in this directory (trash-cli, falls back to rm). Only this directory, even with -r. env: SUMDIR_SHOULD_SINGLE_HASH_FILE"
      ""
      "-o, --out TEMPLATE"
      "    Output file name template. See 'TEMPLATES' below for substitution patterns. env: SUMDIR_OUTPUT_FILE_TEMPLATE"
      ""
      "-l                "
      "    hostname and PWD in output SUMFILE. Affected by -L. env: SUMDIR_SHOULD_INCLUDE_LOCATION_IN_OUTPUT"
      ""
      "-z, --tz TZ"
      "    Set timezone for timestamp; default 'UTC'. env: SUMDIR_TIMEZONE"
      ""
      "-f, --dateformat"
      "    Set format for timestamp (per GNU coreutils date). env: SUMDIR_DATE_FORMAT"
      ""
      "-v, --verbose[=N]  "
      "    Increase the detail of the info output to STDERR. env: SUMDIR_VERBOSE"
      ""
      "-x, --exclude PATTERN"
      "    Exclude files by name, via \`find \\! -name PATTERN\`. env: SUMDIR_LIST_EXCLUDE_NAME"
      ""
      "-X, --exclude-path PATTERN"
      "    Exclude files by name, per \`find \\! -path PATTERN\`; usually of form '*PATTERN*'. env: SUMDIR_LIST_EXCLUDE_PATH"
      ""
      "--time"
      "    (Only with -a sha256e) Add modified time after filename after DELIM."
      ""
      "-d DELIM"
      "    (Only with -a sha256e) Set metadata separator string to DELIM. Defaults to '\\t' Tab character."
      ""
      "--length N        "
      "     (b2sum only) Set the length of the digest hash in bits."
      "     Hashes appear 1/4 this length in hexadecimal (e.g --length 128 yields ."
      "     Default and maximum is 512 (for an output 128 chars long)."
      "     This is the same as setting the env var SUMDIR_LIST_B2_OPTS='--length:N'."
      "--"
      "    After this, all further arguments are passed directly to 'find'."
      ""
      "--bk"
      "    Same as -f '${OPT_OUTPUT_FILE_TEMPLATE_BK}'"
      ""
      "--version"
      "    Output version information"
    );
    local opt;
    for opt in "${SCRIPT_OPTIONS[@]}"; do
      echo "  ${opt}"
    done
    echo "";
    echo "DESCRIPTION:";
    SCRIPT_DESCRIPTION_LINES=(
      "If no PATH is specified, the current directory (\$PWD) is used."
      ""
      "If no SUMFILE is specified, .*SUM* and *SUM* is globbed, and the newest one is used."
      ""
      "TEMPLATES"
      " The following strings are substituted for dynamic values:"
      " '%d' or '{}'  =>  Datetime as formatted by -f"
      " '%a'  =>  Algorithm ('sha256', 'b2', …)"
      " '%A'  =>  Algorithm uppercase ('SHA256', 'B2', …)"
      " "
      ""
      "ENVIRONMENT VARIABLES"
      " *_SHOULD_* options expect 'true' or 'false' values."
      " *_LIST_* options must be colon-separated like PATH."
      ""
      " You may set any of the options above by using the following environment variables."
      " They are shown here with their default values, if available."
    );
    for line in "${SCRIPT_DESCRIPTION_LINES[@]}"; do
      echo "  ${line}"
    done
    for opt in "${OPT_VAR_NAMES[@]}"; do
      echo -n " $(getEnvOptName "$opt")";
      defaultValue="$(getValueIfDefined $(getDefaultOptName "$opt"))" \
        && echo -n "='${defaultValue}'";
      echo; # newline
    done
    echo "";
    echo "EXAMPLES:";
    local exampleIndex=0;
    local exampleColumnCount=${#SCRIPT_EXAMPLE_COLUMNS[@]};
    local exampleColumnIndex=;
    local exampleColumnName=;
    for example in "${SCRIPT_EXAMPLES[@]}"; do
      let 'exampleColumnIndex = exampleIndex % exampleColumnCount';
      exampleColumnName="${SCRIPT_EXAMPLE_COLUMNS[$exampleColumnIndex]}";
      if [[ 'script' == $exampleColumnName ]]; then
        echo "  \$ ${example}";
      elif [[ 'description' == $exampleColumnName ]]; then
        echo "    # ${example}";
      fi
      let 'exampleIndex++';
    done
  }
}

## APPLICATION:
{
  main() {
    local inputDirectories=() userArg;

    setOptsFromEnvAndDefaults;

    while [[ $# -gt 0 ]]; do
      case "$1" in
        -h|--help|help) showHelp | less; exit;;
        -a) opt_algorithm="$2"; shift;;
        -r) opt_should_recurse=true;;
        -L) opt_should_dereference=true;;
        -1|--single) opt_should_single_hash_file=true;;
        -o|--out) opt_output_file_template="$2"; shift;;
        -l) opt_should_include_location_in_output=true;;
        -z|--tz) opt_timezone="$2"; shift;;
        -f|--dateformat) opt_date_format="$2"; shift;;
        -vv) let opt_verbose+=2;;
        -vvv) let opt_verbose+=3;;
        -v|--verbose) let opt_verbose++;;
        --verbose=*) opt_verbose=${1#*=};;
        --length) opt_list_b2_opts+=(--length $2); shift;;
        --time) opt_include_time=true;;
        -d) opt_column_sep="$2"; shift;;
        -x|--exclude) opt_list_exclude_name+=("$2"); shift;;
        -X|--exclude-path) opt_list_exclude_path+=("$2"); shift;;
        --) shift; inputDirectories+=("$@"); shift $#; break;;
        --bk) opt_output_file_template="$OPT_OUTPUT_FILE_TEMPLATE_BK";;
        --version) echo "${SCRIPT_VERSION_NICE} ($0)"; feedback 1 "${SCRIPT_VERSION#*  }" 2>&1; exit;;
        *) inputDirectories+=("$1");;
      esac
      shift;
    done
    feedback 1 "(Verbose output level: ${opt_verbose})";
    export opt_verbose;

    initializeSumCommand;
    initializeJobExecutor;

    export opt_column_sep; # after initializeSumCommand, where it may be reset to empty

    [[ ${#inputDirectories[@]} -eq 0 ]] && inputDirectories=("$PWD");



    ## LOOP THROUGH INPUT DIRECTORIES
    local dStackHeight=0
    local cwd="$PWD";
    local outputFilePath;
    for dir in "${inputDirectories[@]}"; do
      while [[ $dStackHeight -gt 0 ]]; do
        popd &>/dev/null \
          && let dStackHeight--;
      done

      if pushd "$dir" &>/dev/null; then
        let dStackHeight++;
      else
        feedback 0 "Unable to access directory '$dir'. Skipping.";
        continue;
      fi

      if [[ $opt_should_single_hash_file == true ]]; then
        removeFilesByTemplate "$opt_output_file_template";
      fi

      local date="$(TZ="$opt_timezone" date "$opt_date_format")";

      local outputFilename="${opt_output_file_template/\{\}/$date}";
      outputFilename="${outputFilename/\%d/$date}";
      outputFilename="${outputFilename/\%a/$opt_algorithm}";
      outputFilename="${outputFilename/\%A/${algoUpper}}";
      if [[ $outputFilename =~ / ]]; then
        if [[ ${outputFilePath:0:1} == '/' ]]; then
          outputFilePath="$outputFilename";
        else
          outputFilePath="${cwd}/${outputFilename}";
        fi
      else
        outputFilePath="${dir}/${outputFilename}";
      fi

      local findArgs=();
      if [[ $opt_should_dereference == true ]]; then
        findArgs+=(-L);
      fi
      findArgs+=(.);
      if [[ $opt_should_recurse != true ]]; then
        findArgs+=(-maxdepth 1);
      fi
      findArgs+=(-type f);
      findArgs+=(\! -name "$outputFilename");
      if [[ ${#opt_list_exclude_path[@]} -gt 0 ]]; then
        for pattern in "${opt_list_exclude_path[@]}"; do
          findArgs+=(\! -path "$pattern");
        done
      fi
      if [[ ${#opt_list_exclude_name[@]} -gt 0 ]]; then
        for pattern in "${opt_list_exclude_name[@]}"; do
          findArgs+=(\! -name "$pattern");
        done
      fi
      if [[ -n $opt_column_sep ]]; then
        findArgs+=(-printf '%p'"$opt_column_sep"'%TFT%TT %TZ\0');
      else
        findArgs+=(-print0);
      fi

      loglevel 1 && declare -p findArgs
      {
        echo "# Generated ${date} by ${SCRIPT_NAME} ${SCRIPT_VERSION_NICE}  (called as \`${SCRIPT_NAME} $(escapeArgs "${CALL_ARGS[@]}")\`)";
        if [[ -n $opt_column_sep ]]; then
          local colHeader=""
          colHeader+="# ${HEADER_IGNORE_STATEMENT}";
          if [[ $opt_column_sep == '\t' || $opt_column_sep == $'\t' ]]; then
            colHeader+="${HEADER_IGNORE_TAB_LABEL}";
          else
            colHeader+="$(printf %q "$opt_column_sep")";
          fi
          echo "$colHeader";
        fi
        echo "# Same as:  ${sumCommand[*]} FILENAMES";
        echo "# To check file integrity, run:  ${checkCommand[*]} ${outputFilename}";
        local dirPath;
        if [[ $opt_should_include_location_in_output == true ]]; then
          dirPath="${PWD}"
          if [[ $opt_should_dereference == true ]]; then
            dirPath="$(dereferenceSymlink "${PWD}")";
          else
            dirPath="${PWD}"
          fi
          echo "# Location:  $(hostname):${dirPath}";
        fi

        ## Removing leading  `./` in paths.
          #| sed -z 's/^\.\///' \ # BSD sed doesn't have `-z` (sed --version)
          #| perl -pe 's/^\.\///' \ # untested @1666202382 # Pulling this convenience out for now, since it breaks compatibility.
          #| perl -pe 's/(^|\x00)\.\//\1/g' \
        must find "${findArgs[@]}" \
          | sed -E 's/(^|\x00)\.\//\1/g' \
          | "${jobExecutor[@]}" "${sumCommand[@]}" \
          | sort -k2;
      } > "${outputFilePath}";
      local sumStatus=$?;
      feedback 0 "Generated ${outputFilePath}";

      if [[ $sumStatus != 0 ]]; then
        exit $sumStatus;
      fi
    done
  }

  removeFilesByTemplate() {
    local template="$1";

    feedback 2 "Output filename template: ${template}";
    local templateStar="${template//\{\}/*}";
    templateStar="${templateStar//%d/*}";
    templateStar="${templateStar//%a/$opt_algorithm}";
    templateStar="${templateStar//%A/${algoUpper}}";
    feedback 2 "Pattern for files to remove: ${templateStar}";
    local IFS='*';
    local templateParts=($templateStar);
    local idxLastTemplatePart=$(( ${#templateParts[@]} - 1 )); # For Bash 3.2.x compatibility, rather than using index -1.
    if [[ -n ${templateParts[$idxLastTemplatePart]} && $templateStar =~ \*$ ]]; then
      templateParts+=("");
    fi
    IFS="$g_IFS";

    local removeCommand=trash;
    command -v "$removeCommand" &>/dev/null || removeCommand=rm;

    feedback 1 "$ $removeCommand $templateStar";

    case ${#templateParts[@]} in
      0) feedback 1 "No non-wildcard part of name template to glob by, for removing previous output sum files."; return 1;;
      1) feedback 2 "No wildcards in template. Searching for literal name"; $removeCommand "${templateParts[0]}";;
      2) $removeCommand "${templateParts[0]}"*"${templateParts[1]}";;
      3) $removeCommand "${templateParts[0]}"*"${templateParts[1]}"*"${templateParts[2]}";;
      4) $removeCommand "${templateParts[0]}"*"${templateParts[1]}"*"${templateParts[2]}"*"${templateParts[3]}";;
    esac
  }

  initializeSumCommand() {
    # Not `local`: setting in caller context.
    sumCommand=();
    checkCommand=();
    jobExecutor=();
    algoUpper='';
    case "$(echo -n "$opt_algorithm" | toLowerCase)" in
      sha256e|*annex) opt_algorithm=sha256e;
        if ! command -v sha256sum &>/dev/null; then
          die "Missing checksum software: sha256sum or shasum.";
        fi
        sumCommand=(sumSHA256E);
        checkCommand=(checkdir);
        ;;
      sha*) opt_algorithm=sha256;
        if ! command -v sha256sum &>/dev/null; then
          die "Missing checksum software: sha256sum or shasum.";
        fi
        sumCommand=(sha256sum);
        checkCommand=("${sumCommand[@]}" -c);
        if [[ ${#opt_list_sha_opts[@]} -gt 0 ]]; then
          sumCommand+=("${opt_list_sha_opts[@]}");
        fi
        ;;
      b2*|blake*) opt_algorithm=b2;
        sumCommand=(b2sum);
        checkCommand=("${sumCommand[@]}" -c);
        if [[ ${#opt_list_b2_opts[@]} -gt 0 ]]; then
          sumCommand+=("${opt_list_b2_opts[@]}");
        fi
        ;;
      *) die "Unknown sum algorithm '${opt_algorithm}'. Aborting for safety.";;
    esac

    sumCommand+=(--); # no more options, in case filenames/paths begin with `-`.

    if [[ $opt_include_time == true ]]; then
      checkCommand=(checkdir) # Count on checkdir ^0.2.3 to detect separator header.
    fi

    if command -v "${sumCommand[0]}" &>/dev/null; then
      feedback 1 "Using $(which "${sumCommand[0]}")";
    else
      die "Missing selected checksum software: ${sumCommand[0]}.";
    fi
    algoUpper="$(echo "$opt_algorithm" | toUpperCase)";

    if [[ $opt_algorithm != sha256e ]]; then
      opt_column_sep= # Not warning, as it is non-empty by default.
      if [[ $opt_include_time != false ]]; then
        feedback 0 "WARNING: Time metadata is only available with -a sha256e"
        opt_include_time=false
      fi
    fi
  }

  initializeJobExecutor() {
    if command -v parallel &>/dev/null; then
      jobExecutor=(parallel -0 --bar);
    elif command -v xargs &>/dev/null; then
      jobExecutor=(xargsNulWrapper);
    else
      die "Missing parallel and xargs.";
      return 1
    fi;
    if [[ $opt_include_time == true ]]; then
      jobExecutor+=(jobWithMetadata);
    fi
    return 0
  }

  xargsNulWrapper() {
    # Invoking bash in order to access exported functions.
    local bashCommandQuoted=()
    while [[ $# -gt 0 ]]; do
      bashCommandQuoted+=("$(printf %q "$1")");
      shift;
    done
    xargs -i -0 bash -c "${bashCommandQuoted[*]} {}";
  }

  sumSHA256E() {
    local parseArgs=true path basename size sum ext maxExtlen=10
    while [[ $# -gt 0 ]]; do
      if [[ $parseArgs == true && $1 == '--' ]]; then
        shift;
        parseArgs=false;
        continue;
      fi
      path="$1"
      shift
      [[ -n $path ]] || continue
      basename="$(basename "$path")"
      size=($(du -L -b "$path")) || continue
      sum=($(sha256sum "$path")) || continue
      ext="${path##*.}"
      if [[ $ext == $path || $ext == $basename || ${#ext} -gt $maxExtlen ]]; then
        ext=''
      else
        ext=".${ext}"
      fi
      echo "SHA256E-s${size[0]}--${sum[0]}${ext}  ${path}"
    done
  }
  export -f sumSHA256E

  jobWithMetadata() {
    local command=("$1" "$2"); # Assuming $2 is '--'
    shift 2;
    local remainder="$*";
    local buffer= arg=;
    while [[ ${#remainder} -gt 0 ]]; do
      buffer+="${remainder:0:1}";
      remainder="${remainder:1}";
      if [[ $buffer == $opt_column_sep ]]; then
        break;
      elif [[ $buffer != ${opt_column_sep:0:${#buffer}} ]]; then
        arg+="$buffer";
        buffer=;
      fi
    done
    if [[ -n $arg ]]; then
      command+=("$arg");
    fi
    local output;
    output="$("${command[@]}")";
    local status=$?;
    loglevel 1 && >&2 declare -p command output opt_column_sep arg buffer remainder;
    if [[ -n $remainder ]]; then
      output+="${opt_column_sep}${remainder}";
    fi
    echo "$output";
    return $status;
  }
  export -f jobWithMetadata
}

## PLUMBING:
{
  die() { feedback 0 "$@"; exit 111; }; export -f die;
  must() { "$@" || die "cannot $*"; }; export -f must;
  loglevel() { [[ $opt_verbose -ge $1 ]] }; export -f loglevel;
  feedback() { loglevel $1 || return; shift; >&2 echo "$@"; }; export -f feedback;

  getValueIfDefined() {
    varName="$1";
    eval "[ -n \"\${${varName}+v}\" ] && echo -en \"\$${varName}\"";
    local status=$?;
    return $status;
  }

  toLowerCase() {
    #perl -C -lne 'print uc';
    tr '[:upper:]' '[:lower:]';
  }

  toUpperCase() {
    #perl -C -lne 'print uc';
    tr '[:lower:]' '[:upper:]';
  }

  getArrayFromColonList() {
    local varName="$1";
    local colonValue="$2";
    local listValue=();
    local singleValue='';
    while [[ "$colonValue" =~ : ]]; do
      singleValue="${colonValue%%:*}";
      colonValue="${colonValue#*:}"; # Remove first segment from colon-delimited list.
      if [[ -z "$singleValue" ]]; then
        continue;
      fi
      listValue+=("$singleValue");
    done
    listValue+=("${colonValue}");
    eval "${opt}=(\"\${listValue[@]}\")"
  }

  fullPath() {
    local inputPath="$1";
    echo "$(cd "${inputPath%/*}" &>/dev/null && echo -n "${PWD}/${inputPath##*/}")";
  }

  dereferenceSymlink() {
    local linkPath="$1";
    local realPath;
    while [ -L "$linkPath" ]; do
      realPath="$(readlink -- "${linkPath}")";
      if [ ${realPath:0:1} != '/' ]; then
        realPath="$(dirname "${linkPath}")/${realPath}";
      fi
      linkPath="${realPath}";
    done
    fullPath "${linkPath}";
  }

  escapeArgs() {
    local output=;
    while [[ $# -gt 0 ]]; do
      [[ -n $output ]] && output+=' ';
      output+="$(printf %q "$1")"
      shift;
    done
    echo "$output";
  }
  export -f escapeArgs

  if ! command -v sha256sum &>/dev/null && command -v shasum &>/dev/null; then
    sha256sum() { shasum -a 256 "$@"; }
    export -f sha256sum;
  fi
}

## CONFIGURATION:
{
  DEFAULT_ALGORITHM='sha256';
  DEFAULT_COLUMN_SEP='\t';
  DEFAULT_DATE_FORMAT='+%Y%m%dT%H%M%SZ';
  DEFAULT_INCLUDE_TIME=false;
  DEFAULT_LIST_EXCLUDE_NAME='.DS_Store:.thumbnails';
  DEFAULT_LIST_EXCLUDE_PATH='*/.git/*:*/node_modules/*';
  DEFAULT_OUTPUT_FILE_TEMPLATE='.SUM%A--%d'; # previously '.SHA256SUM--{}'
  DEFAULT_SHOULD_DEREFERENCE=false;
  DEFAULT_SHOULD_INCLUDE_LOCATION_IN_OUTPUT=false;
  DEFAULT_SHOULD_RECURSE=false;
  DEFAULT_SHOULD_SINGLE_HASH_FILE=false;
  DEFAULT_TIMEZONE=UTC;
  DEFAULT_VERBOSE=0;
  SCRIPT_NAME="${0##*/}";
  CALL_ARGS=("$@");
  OPT_OUTPUT_FILE_TEMPLATE_BK='%d..%ASUM';
  OPT_VAR_NAMES=(
  opt_algorithm
  opt_column_sep
  opt_date_format
  opt_include_time
  opt_list_b2_opts
  opt_list_exclude_name
  opt_list_exclude_path
  opt_list_sha_opts
  opt_output_file_template
  opt_should_dereference
  opt_should_include_location_in_output
  opt_should_recurse
  opt_should_single_hash_file
  opt_timezone
  opt_verbose # check verbose first
  );
  getDefaultOptName() {
    local opt="$1";
    echo -n "DEFAULT${opt#opt}" | toUpperCase;
  }
  getEnvOptName() {
    local opt="$1";
    echo -n "SUMDIR${opt#opt}" | toUpperCase;
  }
  setOptsFromEnvAndDefaults() {
    local missingEnv=();
    for opt in "${OPT_VAR_NAMES[@]}"; do
      ## Get environment variable.
      fromVarName="$(getEnvOptName "$opt")";
      if ! newValue="$(getValueIfDefined "$fromVarName")"; then
        missingEnv+=("${fromVarName}");

        ## Get default.
        fromVarName="$(getDefaultOptName "$opt")";
        if ! newValue="$(getValueIfDefined "$fromVarName")"; then
          feedback 2 "✗ Missing env and default values for '${opt}'";
          continue;
        fi
      fi

      if [[ $opt =~ ^opt_list_ ]]; then
        if getArrayFromColonList $opt "$newValue"; then
          feedback 1 "✓ ${opt}: (${#listValue[@]})[${listValue[*]}] # from ${fromVarName}";
        else
          feedback 0 "✗ Unable to parse colon-separated list from env var '${fromVarName}'.";
        fi
      else
        eval "${opt}=\"\$newValue\"";
        feedback 1 "✓ ${opt}: \"${newValue}\" # from ${fromVarName}";
      fi
    done
    [[ ${#missingEnv[@]} -gt 0 ]] && feedback 2 "✗ No env vars for options: ${missingEnv[*]}";
  }
}

## EXECUTION:
main "$@";
