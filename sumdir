## DOCUMENTATION:
{
  SCRIPT_USAGE="${0##*/} [OPTIONS] [PATH...]"
  SCRIPT_EXAMPLE_COLUMNS=(script description);
  SCRIPT_EXAMPLES=()
  SCRIPT_EXAMPLES+=("sumdir -r -o ./externalDrive-%d /mnt/externalDrive" "Sum files from a different location, and save output in the current directory.")
  SCRIPT_PURPOSE="Coordinates the generation and output of many checksums."
  SCRIPT_VERSIONS=(
    "0.2.2  @1776735928  Allow adding metadata after arbitrary separator (default TAB); currently only modified time. Fix xargs.  b2sum=f343c91b&size=19278" #nosum
    "0.2.1  @1776282812  Collect PATH args explicitly, rather than passing remainder parent args." #nosum
